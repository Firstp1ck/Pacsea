# Pacsea — example repository definitions (TOML)
#
# What this is
# ------------
# Sample [[repo]] blocks you can copy into your real config. Pacsea does not read this file
# by itself. Your active file is:
#   ~/.config/pacsea/repos.conf
# (You can also open it from the TUI: Config / Lists → Repositories.)
#
# Before you enable anything, check each project’s current docs for mirrors, GPG keys, and
# signing steps — those details change over time.
#
# What each [[repo]] must contain
# -------------------------------
# - name            — Same spelling as the [repo] section in pacman (e.g. blackarch, community).
# - results_filter  — Non-empty label; see the next section for how it ties to settings.
#                     Built-in repo names (core, endeavouros, blackarch, …) still use the
#                     normal title-bar filter toggles for visibility, not this key.
#
# Show/hide custom-repo packages in search (settings.conf)
# --------------------------------------------------------
# This only changes what Pacsea shows in search—it does not remove or disable repos in pacman.
#
# Pacsea converts `results_filter` to a single canonical token: lowercase, and every stretch
# of characters that are not letters or digits is folded to one underscore. Example: my_vendor,
# my-vendor, and My Vendor all become my_vendor. The [Repos] v menu and saved settings use
# that token, not the exact spelling from repos.conf.
#
# In ~/.config/pacsea/settings.conf, for each canonical token:
#   - Omit results_filter_show_<token>  → filter defaults to ON (those packages are shown).
#   - results_filter_show_<token> = false  → hide packages from every [[repo]] that maps to
#     that token in search—for example:
#       results_filter_show_my_vendor = false
#   - Toggling checkboxes under [Repos] v writes the same results_filter_show_* lines.
#
# Example — hide a custom binary repo in Pacsea (search only; pacman repo stays as-is)
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# ~/.config/pacsea/repos.conf
#   [[repo]]
#   name = "myvendor"
#   results_filter = "my-vendor"
#   # … server / keys / etc. when you use Apply — optional for visibility rules above
#
# ~/.config/pacsea/settings.conf  (add this line to hide; omit it to show — default is on)
#   results_filter_show_my_vendor = false
#
# my_vendor is the canonical token for both results_filter = "my-vendor" and "my_vendor".
#
# Repos in the “built-in list” below still use the usual settings (results_filter_show_core,
# results_filter_show_eos, …) for visibility, even if you also have a [[repo]] row for Apply.
#
# Optional fields for “Apply” (Repositories screen, Enter)
# --------------------------------------------------------
# If you add at least one of: server, mirrorlist, or mirrorlist_url, Pacsea can generate a
# managed pacman snippet, optionally import keys, and refresh databases. Roughly:
# - server          — Direct mirror URL for that repo.
# - mirrorlist      — Path on disk to a mirror list file.
# - mirrorlist_url  — HTTPS URL to download a mirror list (needs curl on the system).
# - sig_level       — Trust rules for packages (Pacsea fills a safe default if you omit it).
# - key_id + key_server — Optional: receive and locally sign a key before sync.
# Apply ends with something like pacman -Sy; use --dry-run first if you want to preview.
#
# ---------------------------------------------------------------------------
# Repos Pacsea already knows about (built-in list)
# ---------------------------------------------------------------------------
# Pacsea never writes these into repos.conf for you. When it refreshes the package index, it
# already asks pacman for the databases below. You will only see packages from a name after
# that repo is enabled in /etc/pacman.conf (or a drop-in) and you have synced — e.g. plain
# Arch does not include EndeavourOS or BlackArch until you add them yourself.
#
# Show/hide those packages in search uses the usual Pacsea settings (core, extra, EOS,
# CachyOS, Artix, BlackArch, …). A [[repo]] row here does not replace those toggles when the
# package’s repo name matches this list. README “Supported Platforms” distros align with the
# rows below; Arch’s core/extra/multilib are indexed here but not given recipe stanzas in this
# file (see your distro’s default pacman layout).
#
# Still add a [[repo]] here if you want a saved recipe, or if you use Apply so Pacsea can
# help manage mirrors/keys and the managed drop-in. If pacman already has that repo name,
# Pacsea will not run the same index query twice.
#
#   Arch / Manjaro: core, extra, multilib  (Manjaro also uses community — not in this list)
#   EndeavourOS:    endeavouros
#   CachyOS:        cachyos, cachyos-core, cachyos-extra,
#                   cachyos-v3, cachyos-core-v3, cachyos-extra-v3,
#                   cachyos-v4, cachyos-core-v4, cachyos-extra-v4
#   Artix Linux:    omniverse, universe, lib32, galaxy, world, system
#   BlackArch:      blackarch
#
# Repo names pacman knows but that are not above (e.g. Manjaro’s community) only get an extra
# index pass if you add them here with the same name pacman uses.

# ---------------------------------------------------------------------------
# Commented recipes — README supported platforms (no standard Arch core/extra/multilib stanzas)
# ---------------------------------------------------------------------------
# Uncomment and edit one block at a time. Match upstream docs for URLs, SigLevel, and keys
# before using Apply. Every [[repo]] still needs name + results_filter even when the label
# is only for your own clarity.

# --- EndeavourOS [endeavouros] (mirrors: endeavouros-team PKGBUILDS `endeavouros-mirrorlist`) ---
# [[repo]]
# id = "endeavouros"
# name = "endeavouros"
# results_filter = "endeavouros"
# server = "https://mirror.alpix.eu/endeavouros/repo/$repo/$arch"
# sig_level = "PackageRequired"
# # Keys: EndeavourOS docs / endeavouros-keyring.

# --- CachyOS (https://wiki.cachyos.org/cachyos_repositories/how_to_add_cachyos_repo/) ---
# Same `server` pattern for every [cachyos*] section you enable; pick one tier (x86-64,
# x86-64-v3, x86-64-v4) and only enable matching repo triplets. Mirror: CachyOS-PKGBUILDS
# `cachyos-mirrorlist` / `cachyos-v3-mirrorlist` / `cachyos-v4-mirrorlist`.
# key_id from wiki / cachyos-keyring (verify): F3B607488DB35A47
#
# Base (x86-64):
# [[repo]]
# id = "cachyos"
# name = "cachyos"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-core"
# name = "cachyos-core"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-extra"
# name = "cachyos-extra"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# x86-64-v3:
# [[repo]]
# id = "cachyos-v3"
# name = "cachyos-v3"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-core-v3"
# name = "cachyos-core-v3"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-extra-v3"
# name = "cachyos-extra-v3"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# x86-64-v4:
# [[repo]]
# id = "cachyos-v4"
# name = "cachyos-v4"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-core-v4"
# name = "cachyos-core-v4"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"
#
# [[repo]]
# id = "cachyos-extra-v4"
# name = "cachyos-extra-v4"
# results_filter = "cachyos"
# server = "https://cdn77.cachyos.org/repo/$arch/$repo"
# sig_level = "Required DatabaseOptional"
# key_id = "F3B607488DB35A47"
# key_server = "keyserver.ubuntu.com"

# --- Artix Linux (mirror pattern from packages `artix-mirrorlist`; https://wiki.artixlinux.org/Main/Repositories ) ---
# Use `Server = .../$repo/os/$arch` so each [section] resolves; on Artix, Include=mirrorlist is usual.
#
# [[repo]]
# id = "artix-system"
# name = "system"
# results_filter = "artix_system"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
# # Trust: artix-keyring / Artix signing docs.
#
# [[repo]]
# id = "artix-world"
# name = "world"
# results_filter = "artix_world"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
#
# [[repo]]
# id = "artix-galaxy"
# name = "galaxy"
# results_filter = "artix_galaxy"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
#
# [[repo]]
# id = "artix-lib32"
# name = "lib32"
# results_filter = "artix_lib32"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
#
# [[repo]]
# id = "artix-universe"
# name = "universe"
# results_filter = "artix_universe"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
#
# [[repo]]
# id = "artix-omniverse"
# name = "omniverse"
# results_filter = "artix_omniverse"
# server = "https://mirrors.rit.edu/artixlinux/$repo/os/$arch"
# sig_level = "Required DatabaseOptional"
# # Omniverse was deprecated upstream (Artix wiki, 2026); Pacsea may still query the name on old systems.

# --- BlackArch (https://blackarch.org/ — strap.sh / FAQ; mirrorlist also common) ---
# [[repo]]
# id = "blackarch"
# name = "blackarch"
# results_filter = "blackarch"
# server = "https://blackarch.org/blackarch/$repo/os/$arch"
# sig_level = "DatabaseOptional TrustedOnly"
# # strap.sh verifies key fingerprint 4345771566D76038C7FEB43863EC0ADBEA87E4E3
# key_id = "4345771566D76038C7FEB43863EC0ADBEA87E4E3"
# key_server = "keyserver.ubuntu.com"

# --- Manjaro [community] (https://manjaro.org/ — not in Pacsea’s built-in index list above)
# `community` is separate from core/extra/multilib; add this row if you want repos.conf-driven
# indexing or Apply for that database. Mirrors: follow Manjaro wiki / your ISO defaults.
# [[repo]]
# id = "manjaro-community"
# name = "community"
# results_filter = "community"
# mirrorlist = "/etc/pacman.d/mirrorlist"
# sig_level = "Required DatabaseOptional"

# Minimal custom mirror (placeholders only):
# [[repo]]
# id = "vendor"
# name = "myrepo"
# results_filter = "vendor_pkgs"
# server = "https://example.com/$repo/$arch"
# sig_level = "Required DatabaseOptional"
# key_id = "YOURKEYID"
# key_server = "keyserver.ubuntu.com"
#
# Mirrorlist from URL (needs curl installed):
# [[repo]]
# name = "myrepo"
# results_filter = "vendor_pkgs"
# mirrorlist_url = "https://example.org/mirrorlist.txt"
